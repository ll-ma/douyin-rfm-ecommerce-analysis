      <aliases enabled='yes' />
      <column caption='Average Order Value' datatype='real' name='[Average_Order_Value]' role='measure' type='quantitative' />
      <column caption='GMV占比%' datatype='real' name='[Calculation_77687144243904513]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [macro_segment] : SUM([Total_Spending]) }&#13;&#10;/ { FIXED : SUM([Total_Spending]) }' />
      </column>
      <column caption='区域内分群占比' datatype='real' name='[Calculation_77687144243990530]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Location],[macro_segment] : COUNT([User_ID]) }&#13;&#10;/ { FIXED [Location] : COUNT([User_ID]) }' />
      </column>
      <column caption='分群排序' datatype='integer' name='[Calculation_77687144244117507]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [macro_segment]&#13;&#10;  WHEN &apos;核心客户&apos; THEN 1&#13;&#10;  WHEN &apos;重要客户&apos; THEN 2&#13;&#10;  WHEN &apos;潜力客户&apos; THEN 3&#13;&#10;  WHEN &apos;一般客户&apos; THEN 4&#13;&#10;  WHEN &apos;流失客户&apos; THEN 5&#13;&#10;  ELSE 99&#13;&#10;END' />
      </column>
      <column caption='订阅率' datatype='real' name='[Calculation_77687144252784645]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Newsletter_Subscription] = &quot;t&quot; THEN 1 ELSE 0 END)&#13;&#10;/ COUNT([User_ID])' />
      </column>
      <column caption='兴趣匹配' datatype='integer' name='[Calculation_77687144283066380]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Interests] = &quot;Fashion&quot;     AND [Product_Category_Preference] IN (&quot;Apparel&quot;,&quot;Electronics&quot;)&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSEIF [Interests] = &quot;Technology&quot; AND [Product_Category_Preference] IN (&quot;Electronics&quot;,&quot;Books&quot;)&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSEIF [Interests] = &quot;Food&quot;       AND [Product_Category_Preference] IN (&quot;Home &amp; Kitchen&quot;,&quot;Health &amp; Beauty&quot;,&quot;Books&quot;)&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSEIF [Interests] = &quot;Sports&quot;     AND [Product_Category_Preference] IN (&quot;Apparel&quot;,&quot;Electronics&quot;,&quot;Books&quot;)&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSEIF [Interests] = &quot;Travel&quot;     AND [Product_Category_Preference] IN (&quot;Apparel&quot;,&quot;Electronics&quot;,&quot;Books&quot;)&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='兴趣匹配率' datatype='real' name='[Calculation_77687144283475981]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_77687144283066380]) / COUNT([User_ID])' />
      </column>
      <column caption='Last Login Days Ago' datatype='integer' name='[Last_Login_Days_Ago]' role='measure' type='quantitative' />
      <column caption='Newsletter Subscription' datatype='string' datatype-customized='true' name='[Newsletter_Subscription]' role='dimension' type='nominal' />
      <column caption='Pages Viewed' datatype='integer' name='[Pages_Viewed]' role='measure' type='quantitative' />
      <column caption='Product Category Preference' datatype='string' name='[Product_Category_Preference]' role='dimension' type='nominal' />
