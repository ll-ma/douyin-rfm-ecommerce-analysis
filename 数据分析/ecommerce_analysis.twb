    <worksheet name='兴趣匹配率'>
      <table>
        <view>
          <datasources>
            <datasource caption='rfm_main' name='federated.1f94d300r1k6bp12ae4h71wcpt9a' />
          </datasources>
          <datasource-dependencies datasource='federated.1f94d300r1k6bp12ae4h71wcpt9a'>
            <column caption='兴趣匹配' datatype='integer' name='[Calculation_77687144283066380]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Interests] = &quot;Fashion&quot;     AND [Product_Category_Preference] IN (&quot;Apparel&quot;,&quot;Electronics&quot;)&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSEIF [Interests] = &quot;Technology&quot; AND [Product_Category_Preference] IN (&quot;Electronics&quot;,&quot;Books&quot;)&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSEIF [Interests] = &quot;Food&quot;       AND [Product_Category_Preference] IN (&quot;Home &amp; Kitchen&quot;,&quot;Health &amp; Beauty&quot;,&quot;Books&quot;)&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSEIF [Interests] = &quot;Sports&quot;     AND [Product_Category_Preference] IN (&quot;Apparel&quot;,&quot;Electronics&quot;,&quot;Books&quot;)&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSEIF [Interests] = &quot;Travel&quot;     AND [Product_Category_Preference] IN (&quot;Apparel&quot;,&quot;Electronics&quot;,&quot;Books&quot;)&#13;&#10;THEN 1&#13;&#10;&#13;&#10;ELSE 0&#13;&#10;END' />
            </column>
            <column caption='兴趣匹配率' datatype='real' name='[Calculation_77687144283475981]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Calculation_77687144283066380]) / COUNT([User_ID])' />
            </column>
            <column datatype='string' name='[Interests]' role='dimension' type='nominal' />
            <column caption='Product Category Preference' datatype='string' name='[Product_Category_Preference]' role='dimension' type='nominal' />
            <column caption='User ID' datatype='string' datatype-customized='true' name='[User_ID]' role='dimension' type='nominal' />
